{
   "extends": "expo/tsconfig.base",
   "compilerOptions": {
      "strict": true,
      "allowJs": true,
      "jsx": "react-native",
      "baseUrl": "./",
      "paths": {
         "@/*": ["./*"]
      }
   },
   "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", ".expo/types/**/*.ts", "expo-env.d.ts", "global.d.ts"],
   "exclude": ["node_modules", "android", "ios"]
}
